{
  "entities": {
    "Case": {
      "title": "Case",
      "type": "object",
      "description": "Represents a social case for displaced and vulnerable people.",
      "properties": {
        "id": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "documentId": { "type": "string" },
        "internalId": { "type": "string" },
        "municipality": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "object" },
        "userId": { "type": "string" },
        "members": { "type": "object" }
      }
    },
    "PublicCaseStatus": {
      "title": "PublicCaseStatus",
      "type": "object",
      "description": "Secure public view of case progress.",
      "properties": {
        "documentId": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "status": { "type": "string" },
        "municipality": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    },
    "PublicCaseQuery": {
      "title": "PublicCaseQuery",
      "type": "object",
      "description": "Audit log of public identification queries.",
      "properties": {
        "documentId": { "type": "string" },
        "caseNumber": { "type": "string" },
        "statusAtQuery": { "type": "string" },
        "consultedAt": { "type": "object" },
        "result": { "type": "string", "enum": ["found", "not_found"] }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "Internal notification for users regarding case updates.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "read": { "type": "boolean" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Extended user profile data stored in Firestore.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "case-worker"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "documentType": { "type": "string" },
        "documentNumber": { "type": "string" },
        "gender": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Full private case data."
    },
    "/cases/{caseId}/novedades/{novedadId}": {
      "schema": "object",
      "description": "History of interactions and calls."
    },
    "/publicCaseStatus/{documentId}": {
      "schema": "PublicCaseStatus",
      "description": "Limited public access for status checks."
    },
    "/publicCaseQueries/{queryId}": {
      "schema": "PublicCaseQuery",
      "description": "Traceability of public queries."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Internal notifications."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and permissions."
    },
    "/mensajes/{mensajeId}": {
      "schema": "object",
      "description": "Citizen contact messages."
    }
  }
}