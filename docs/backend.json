
{
  "entities": {
    "Case": {
      "title": "Case",
      "type": "object",
      "description": "Represents a social case for displaced and vulnerable people.",
      "properties": {
        "id": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "documentId": { "type": "string" },
        "municipality": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PublicCaseStatus": {
      "title": "PublicCaseStatus",
      "type": "object",
      "description": "Secure public view of case progress.",
      "properties": {
        "documentId": { "type": "string", "description": "Normalized ID number (only digits)." },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "status": { "type": "string" },
        "municipality": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["documentId", "caseNumber", "status", "municipality", "firstName", "lastName"]
    },
    "PublicCaseQueryLog": {
      "title": "PublicCaseQueryLog",
      "type": "object",
      "description": "Audit log for public case status queries.",
      "properties": {
        "documentId": { "type": "string" },
        "caseNumber": { "type": "string" },
        "statusAtQuery": { "type": "string" },
        "consultedAt": { "type": "string", "format": "date-time" },
        "result": { "type": "string", "enum": ["found", "not_found"] }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "Internal notification for users regarding case updates.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["userId", "caseId", "message", "createdAt", "read"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Extended user profile data stored in Firestore.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "case-worker"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Full private case data."
    },
    "/cases/{caseId}/novedades/{novedadId}": {
      "schema": "object",
      "description": "History of interactions and calls for a specific case."
    },
    "/publicCaseStatus/{documentId}": {
      "schema": "PublicCaseStatus",
      "description": "Limited public access for status checks."
    },
    "/publicCaseQueries/{queryId}": {
      "schema": "PublicCaseQueryLog",
      "description": "Traceability log for public queries."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Internal notifications for case management updates."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and permissions."
    },
    "/mensajes/{mensajeId}": {
      "schema": "object",
      "description": "Citizen inquiries from the contact form."
    }
  }
}
