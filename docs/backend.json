
{
  "entities": {
    "Case": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Case",
      "type": "object",
      "description": "Represents a social case for displaced and vulnerable people.",
      "properties": {
        "id": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "documentType": { "type": "string" },
        "documentId": { "type": "string" },
        "internalId": { "type": "string" },
        "ethnicGroup": { "type": "string" },
        "maritalStatus": { "type": "string" },
        "gender": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "address": { "type": "string" },
        "locality": { "type": "string" },
        "department": { "type": "string" },
        "cellphone1": { "type": "string" },
        "cellphone2": { "type": "string" },
        "displacementType": { "type": "string" },
        "disability": { "type": "string" },
        "age": { "type": "number" },
        "isElderly": { "type": "boolean" },
        "peopleCount": { "type": "number" },
        "testimony": { "type": "string" },
        "status": { "type": "string" },
        "members": { "type": "object" }
      },
      "required": ["id", "caseNumber", "firstName", "lastName", "documentType", "documentId", "ethnicGroup", "maritalStatus", "gender", "birthDate", "address", "locality", "department", "cellphone1", "displacementType", "age", "isElderly", "peopleCount", "testimony", "status"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "System user profile including roles.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "case-worker"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "System notification for users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "userId", "caseId", "message", "createdAt", "read"]
    },
    "AuthorizedEmail": {
      "title": "AuthorizedEmail",
      "type": "object",
      "description": "Emails pre-authorized by an admin to register in the platform.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "addedBy": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "addedBy", "addedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/cases/{caseId}",
        "definition": {
          "entityName": "Case",
          "schema": { "$ref": "#/backend/entities/Case" },
          "description": "Stores case data."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile and roles."
        }
      },
      {
        "path": "/notifications/{notificationId}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "Stores user notifications."
        }
      },
      {
        "path": "/authorized_emails/{emailId}",
        "definition": {
          "entityName": "AuthorizedEmail",
          "schema": { "$ref": "#/backend/entities/AuthorizedEmail" },
          "description": "Whitelist of emails allowed to sign up."
        }
      }
    ]
  }
}
