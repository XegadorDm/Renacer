{
  "entities": {
    "Case": {
      "title": "Case",
      "type": "object",
      "description": "Representa un caso social detallado de una persona vulnerable.",
      "properties": {
        "id": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "documentId": { "type": "string" },
        "internalId": { "type": "string" },
        "municipality": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "object" },
        "userId": { "type": "string" },
        "members": { "type": "object" },
        "testimony": { "type": "string" },
        "phone1": { "type": "string" },
        "phone2": { "type": "string" },
        "address": { "type": "string" },
        "department": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "maritalStatus": { "type": "string" },
        "ethnicGroup": { "type": "string" },
        "displacementType": { "type": "string" },
        "disability": { "type": "string" },
        "isElderly": { "type": "boolean" },
        "householdMembers": { "type": "number" },
        "birthDate": { "type": "string", "format": "date-time" }
      }
    },
    "PublicCaseStatus": {
      "title": "PublicCaseStatus",
      "type": "object",
      "description": "Espejo simplificado del caso para consulta pública por cédula.",
      "properties": {
        "documentId": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "status": { "type": "string" },
        "municipality": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    },
    "PublicCaseQuery": {
      "title": "PublicCaseQuery",
      "type": "object",
      "description": "Registro de auditoría de búsquedas en la landing page.",
      "properties": {
        "documentId": { "type": "string" },
        "caseNumber": { "type": "string" },
        "statusAtQuery": { "type": "string" },
        "consultedAt": { "type": "object" },
        "result": { "type": "string", "enum": ["found", "not_found"] }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "Notificación interna sobre actualizaciones de casos.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "read": { "type": "boolean" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil extendido de asesores y administradores.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "case-worker"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "documentType": { "type": "string" },
        "documentNumber": { "type": "string" },
        "gender": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Novedad": {
      "title": "Novedad",
      "type": "object",
      "description": "Entrada en el historial de trazabilidad de un caso.",
      "properties": {
        "mensaje": { "type": "string" },
        "tipo": { "type": "string", "enum": ["llamada", "nota", "sistema"] },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" }
      }
    },
    "Mensaje": {
      "title": "Mensaje",
      "type": "object",
      "description": "Mensaje de contacto enviado por un ciudadano.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "email": { "type": "string" },
        "cedula": { "type": "string" },
        "asunto": { "type": "string" },
        "mensaje": { "type": "string" },
        "read": { "type": "boolean" },
        "resolved": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Datos privados de casos sociales."
    },
    "/cases/{caseId}/novedades/{novedadId}": {
      "schema": "Novedad",
      "description": "Historial de interacciones del caso."
    },
    "/publicCaseStatus/{documentId}": {
      "schema": "PublicCaseStatus",
      "description": "Vista pública segura (indexada por cédula)."
    },
    "/publicCaseQueries/{queryId}": {
      "schema": "PublicCaseQuery",
      "description": "Trazabilidad de consultas ciudadanas."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Alertas internas para el equipo."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Gestión de personal y permisos."
    },
    "/mensajes/{mensajeId}": {
      "schema": "Mensaje",
      "description": "Buzón de ciudadanos."
    }
  }
}