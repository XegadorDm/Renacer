{
  "entities": {
    "Case": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Case",
      "type": "object",
      "description": "Represents a social case for displaced and vulnerable people.",
      "properties": {
        "id": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "documentId": { "type": "string" },
        "internalId": { "type": "string" },
        "ethnicGroup": { "type": "string" },
        "maritalStatus": { "type": "string" },
        "gender": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "address": { "type": "string" },
        "locality": { "type": "string" },
        "municipality": { "type": "string" },
        "department": { "type": "string" },
        "phone1": { "type": "string" },
        "phone2": { "type": "string" },
        "displacementType": { "type": "string" },
        "disability": { "type": "string" },
        "age": { "type": "number" },
        "isElderly": { "type": "boolean" },
        "peopleCount": { "type": "number" },
        "testimony": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" },
        "members": { "type": "object" }
      },
      "required": ["id", "caseNumber", "firstName", "lastName", "documentId", "ethnicGroup", "maritalStatus", "gender", "birthDate", "address", "municipality", "department", "phone1", "displacementType", "age", "isElderly", "peopleCount", "testimony", "status"]
    },
    "Novedad": {
      "title": "Novedad",
      "type": "object",
      "description": "Log entry for case follow-ups (calls, notes, etc).",
      "properties": {
        "mensaje": { "type": "string" },
        "tipo": { "type": "string", "enum": ["llamada", "nota", "sistema"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["mensaje", "tipo", "createdAt", "createdBy"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "System user profile including roles.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "case-worker"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "AuthorizedEmail": {
      "title": "AuthorizedEmail",
      "type": "object",
      "description": "Emails pre-authorized by an admin to register in the platform.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "addedBy": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "addedBy", "addedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/cases/{caseId}",
        "definition": {
          "entityName": "Case",
          "schema": { "$ref": "#/backend/entities/Case" },
          "description": "Stores case data."
        }
      },
      {
        "path": "/cases/{caseId}/novedades/{novedadId}",
        "definition": {
          "entityName": "Novedad",
          "schema": { "$ref": "#/backend/entities/Novedad" },
          "description": "Historical log of actions taken on a case."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile and roles."
        }
      },
      {
        "path": "/authorized_emails/{emailId}",
        "definition": {
          "entityName": "AuthorizedEmail",
          "schema": { "$ref": "#/backend/entities/AuthorizedEmail" },
          "description": "Whitelist of emails allowed to sign up."
        }
      }
    ]
  }
}