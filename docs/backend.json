{
  "entities": {
    "Case": {
      "title": "Case",
      "type": "object",
      "description": "Representa un caso social detallado de una persona vulnerable.",
      "properties": {
        "id": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "documentId": { "type": "string" },
        "internalId": { "type": "string" },
        "municipality": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "object" },
        "userId": { "type": "string" },
        "members": { "type": "object" },
        "testimony": { "type": "string" },
        "phone1": { "type": "string" },
        "phone2": { "type": "string" },
        "address": { "type": "string" },
        "department": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "maritalStatus": { "type": "string" },
        "ethnicGroup": { "type": "string" },
        "displacementType": { "type": "string" },
        "disability": { "type": "string" },
        "isElderly": { "type": "boolean" },
        "householdMembers": { "type": "number" },
        "birthDate": { "type": "string", "format": "date-time" }
      }
    },
    "PublicCaseStatus": {
      "title": "PublicCaseStatus",
      "type": "object",
      "description": "Espejo simplificado del caso para consulta pública segura.",
      "properties": {
        "documentId": { "type": "string" },
        "caseNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "status": { "type": "string" },
        "municipality": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil extendido de personal administrativo y asesores.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "case-worker"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" }
      }
    },
    "Novedad": {
      "title": "Novedad",
      "type": "object",
      "description": "Registro de actividad o seguimiento de un caso.",
      "properties": {
        "id": { "type": "string" },
        "mensaje": { "type": "string" },
        "tipo": { "type": "string", "enum": ["llamada", "nota", "sistema"] },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" }
      }
    },
    "Mensaje": {
      "title": "Mensaje",
      "type": "object",
      "description": "Mensaje recibido desde el formulario de contacto externo.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "email": { "type": "string" },
        "cedula": { "type": "string" },
        "asunto": { "type": "string" },
        "mensaje": { "type": "string" },
        "read": { "type": "boolean" },
        "resolved": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Colección privada de caracterizaciones sociales."
    },
    "/cases/{caseId}/novedades/{novedadId}": {
      "schema": "Novedad",
      "description": "Historial de seguimiento de un caso."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Gestión de personal interno."
    },
    "/publicCaseStatus/{documentId}": {
      "schema": "PublicCaseStatus",
      "description": "Índice público para consulta ciudadana por cédula."
    },
    "/mensajes/{mensajeId}": {
      "schema": "Mensaje",
      "description": "Buzón de consultas ciudadanas."
    }
  }
}