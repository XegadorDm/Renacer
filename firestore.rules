
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Bypass prioritario para administradores core del proyecto
    function isCoreAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // Verifica aprobación de forma segura (sin fallar si el doc no existe)
    function isApproved() {
      return isCoreAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
      );
    }

    // Verifica rol de administrador
    function isAdmin() {
      return isCoreAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Colección de Casos (REQ-006, REQ-008)
    match /cases/{caseId} {
      allow get, list: if isApproved();
      allow create, update: if isApproved();
      allow delete: if isAdmin();

      // Trazabilidad de novedades
      match /novedades/{novedadId} {
        allow read, list, create: if isApproved();
      }
    }

    // Vista Pública Segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true; // Lectura individual por cédula
      allow list: if false; // Prohibido listar todos
      allow write: if isApproved(); // Solo internos aprobados escriben
    }

    // Auditoría de Consultas Públicas (REQ-007)
    match /publicCaseQueries/{queryId} {
      allow create: if true; 
      allow read, list: if isApproved(); 
    }

    // Notificaciones Internas (REQ-008)
    match /notifications/{notificationId} {
      allow create: if isApproved();
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // Mensajes de contacto ciudadanos
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update: if isApproved();
      allow delete: if isAdmin();
    }
  }
}
