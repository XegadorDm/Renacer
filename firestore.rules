rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PERMISIVIDAD TOTAL PARA USUARIOS AUTENTICADOS
    // Esto garantiza que cualquier asesor o administrador logueado pueda 
    // crear, leer, editar y cambiar estados sin bloqueos de "insufficient permissions".
    // Forzando despliegue de reglas para asegurar que el cambio surta efecto de inmediato.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}