rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Bypass prioritario para administradores core del proyecto (Infalible)
    function isCoreAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // Verifica si el usuario tiene un perfil aprobado en la base de datos
    function isApproved() {
      return isCoreAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
      );
    }

    // Verifica si el usuario tiene rol de administrador
    function isAdmin() {
      return isCoreAdmin() || (
        isApproved() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios: Los usuarios ven su propio perfil, admins ven todo
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Colección de Casos (REQ-006, REQ-008)
    match /cases/{caseId} {
      // Reglas explícitas para evitar ambigüedad en operaciones de lista
      allow get, list: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdmin();

      // Historial de novedades (trazabilidad)
      match /novedades/{novedadId} {
        allow read, list, create: if isApproved();
      }
    }

    // Vista Pública Segura (REQ-007): Lectura individual por cédula permitida a todos
    match /publicCaseStatus/{documentId} {
      allow get: if true; 
      allow list: if false; // Prohibido listar todos por privacidad
      allow write: if isApproved(); // Solo internos aprobados escriben el espejo
    }

    // Auditoría de Consultas Públicas
    match /publicCaseQueries/{queryId} {
      allow create: if true; 
      allow read, list: if isApproved(); 
    }

    // Notificaciones Internas
    match /notifications/{notificationId} {
      allow create: if isApproved();
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // Mensajes de contacto ciudadanos
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update: if isApproved();
      allow delete: if isAdmin();
    }
  }
}