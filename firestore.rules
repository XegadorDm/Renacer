/**
 * @fileOverview Firestore Security Rules for the "cases" collection.
 *
 * Core Philosophy:
 * This ruleset enforces a shared access model using a `members` map on each `/cases/{caseId}` document.
 * Users must be authenticated to access any data.
 * Access to a case is determined by the presence and role of the user's UID within the `members` map on the case document.
 *
 * Data Structure:
 * - /cases/{caseId}: Each document represents a case. The 'members' field is a map of user IDs to roles (e.g., {uid1: 'owner', uid2: 'viewer'}).
 *
 * Key Security Decisions:
 * - Users must be authenticated to access the application.
 * - Cases are not publicly listable.
 * - Writes are restricted to authenticated users with appropriate roles in the 'members' map.
 * - The 'members' map can only be updated by users with 'owner' role.
 *
 * Denormalization for Authorization:
 * - The 'members' map is denormalized directly onto each `/cases/{caseId}` document. This avoids costly `get()` calls and enables efficient authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to individual case documents.
     * @path /cases/{caseId}
     * @allow (get) Authenticated user with 'viewer' or higher role in case's 'members' map can read.
     *       Example: User 'user_abc' with role 'viewer' can get the case.
     * @allow (list) Listing cases is not permitted.
     * @allow (create) Authenticated user can create a case if they are the owner.
     *       Example: User 'user_abc' creates a new case and is automatically assigned 'owner' role.
     * @allow (update) Authenticated user with 'editor' or 'owner' role in case's 'members' map can update.
     *       Example: User 'user_abc' with role 'editor' updates the case details.
     * @allow (delete) Authenticated user with 'owner' role in case's 'members' map can delete.
     *       Example: User 'user_abc' with role 'owner' deletes the case.
     * @deny (get) User not authenticated can't read.
     *       Example: Anonymous user tries to get a case.
     * @deny (create) User not authenticated can't create.
     *       Example: Anonymous user tries to create a case.
     * @deny (update) User not authenticated or without 'editor' or 'owner' role can't update.
     *       Example: User 'user_def' without access tries to update the case.
     * @deny (delete) User not authenticated or without 'owner' role can't delete.
     *       Example: User 'user_def' without 'owner' role tries to delete the case.
     * @principle Enforces role-based access control for cases.
     */
    match /cases/{caseId} {
      // Read Rules
      allow get: if isSignedIn() && hasRole(resource.data.members, 'viewer');
      allow list: if false;

      // Write Rules
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isExistingCaseEditor(resource.data.members);
      allow delete: if isSignedIn() && isExistingCaseOwner(resource.data.members);
    }

    // ------ Helper Functions ------

    /**
     * @description Checks if the user is signed in.
     * @returns {boolean} True if the user is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user has the specified role in the members map.
     * @param {map} members - The members map of the document.
     * @param {string} role - The role to check for (e.g., 'owner', 'editor', 'viewer').
     * @returns {boolean} True if the user has the specified role or a higher role, false otherwise.
     */
    function hasRole(members, role) {
      return isSignedIn() && (
        members[request.auth.uid] == 'owner' ||
        (role == 'viewer' && (members[request.auth.uid] == 'viewer' || members[request.auth.uid] == 'editor')) ||
        (role == 'editor' && (members[request.auth.uid] == 'editor'))
      );
    }

   /**
     * @description Checks if the user has 'owner' role in the existing document.
     * @param {map} members - The members map of the document.
     * @returns {boolean} True if the user is the owner, and the document exists.
     */
    function isExistingCaseOwner(members) {
        return hasRole(members, 'owner');
    }

   /**
     * @description Checks if the user has 'editor' role in the existing document.
     * @param {map} members - The members map of the document.
     * @returns {boolean} True if the user is an editor, and the document exists.
     */
      function isExistingCaseEditor(members) {
        return hasRole(members, 'editor');
    }
  }
}