rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD SIMPLIFICADAS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Administrador Core (Bypass)
    function isCoreAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios: Acceso total para gestión interna
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Colección de Casos: ACCESO TOTAL para cualquier usuario del dashboard (REQ-006 compatible)
    match /cases/{caseId} {
      allow read, write: if isAuthenticated();

      match /novedades/{novedadId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Vista Pública Segura (REQ-007): Solo lectura por ID para ciudadanos
    match /publicCaseStatus/{documentId} {
      allow get: if true; 
      allow list: if false;
      allow write: if isAuthenticated();
    }

    // Auditoría y Notificaciones
    match /publicCaseQueries/{queryId} {
      allow create: if true; 
      allow read, list: if isAuthenticated(); 
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    // Buzón de Mensajes (REQ-008)
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, write: if isAuthenticated();
    }
    
    match /authorized_emails/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}