rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DESPLIEGUE DE EMERGENCIA: 2024-05-24 15:30:00 UTC
    // Estas reglas permiten el acceso total a usuarios autenticados para evitar bloqueos en la gestión de casos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Acceso público necesario para la verificación inicial en el registro
    match /authorized_emails/{document=**} {
      allow read: if true;
    }
  }
}