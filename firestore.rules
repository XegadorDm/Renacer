rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SYNC_ID: RENACER_BUZON_RULES_V1900

    // Función auxiliar robusta para obtener el rol
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Reglas para la colección de casos
    match /cases/{caseId} {
      allow read: if request.auth != null;

      // Solo el rol 'admin' puede borrar documentos
      allow delete: if request.auth != null && getRole() == 'admin';

      // Administradores y Trabajadores Sociales pueden crear y editar
      allow create, update: if request.auth != null && (getRole() == 'admin' || getRole() == 'case-worker');

      match /novedades/{novedadId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      }
    }

    // Reglas para el buzón de mensajes (Contacto Público)
    match /mensajes/{mensajeId} {
      // Cualquier persona puede enviar un mensaje desde la landing page (acceso público)
      allow create: if true;
      // Solo usuarios autenticados (personal de Renacer) pueden leer el buzón
      allow read: if request.auth != null;
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      // Permitimos lectura total a usuarios logueados para que getRole() no falle nunca
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}