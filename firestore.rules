rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RENACER - DESPLIEGUE FINAL DE EMERGENCIA V800
    // Sincronización forzada para resolver error de permisos de forma definitiva
    // Permitir acceso total de lectura y escritura a cualquier usuario autenticado
    // Identificador de sincronización: SYNC_ID_RENACER_FINAL_V800_STABLE
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regla explícita para la subcolección de novedades por seguridad adicional
    match /cases/{caseId}/novedades/{novedadId} {
      allow read, write: if request.auth != null;
    }
  }
}