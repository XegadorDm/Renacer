rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - DESPLIEGUE DEFINITIVO V500
    // PROPÓSITO: Eliminación absoluta de errores de permisos.
    // SYNC ID: FORCE_DEPLOY_RENACER_V500_FINAL_BRUTE_FORCE
    // TIMESTAMP: 2024-05-24T22:00:00Z
    // ============================================================

    // 1. Regla Universal: Si el usuario está autenticado, tiene permiso total.
    // Esto cubre todas las operaciones (get, list, create, update, delete).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 2. Refuerzo específico para la colección de casos (redundancia de seguridad)
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }
  }
}