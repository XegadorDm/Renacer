rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS GLOBALES DE EMERGENCIA - PERMISO TOTAL A USUARIOS AUTENTICADOS
    // DESPLIEGUE FORZADO: 2024-03-20 14:00:00
    // ============================================================
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    match /cases/{caseId} {
      // Regla explícita para asegurar el cambio de estado (status)
      allow read, write, update: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /authorized_emails/{emailId} {
      allow read, write: if request.auth != null;
    }
  }
}
