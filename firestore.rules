rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - DESPLIEGUE FINAL DE EMERGENCIA
    // PROPÓSITO: Garantizar permisos de actualización para novedades de llamadas.
    // TIMESTAMP: 2024-05-22T15:30:00Z (FORCE SYNC)
    // ============================================================

    // Permitir acceso total a cualquier usuario autenticado en toda la base de datos
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Reglas explícitas para la colección de casos
    match /cases/{caseId} {
      allow read, write, update, delete: if request.auth != null;
    }
    
    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para correos autorizados
    match /authorized_emails/{emailId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
