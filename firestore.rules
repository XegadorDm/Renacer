rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SYNC_ID: RENACER_PUBLIC_SEARCH_V2100

    // Función auxiliar robusta para obtener el rol del usuario autenticado
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Reglas para la colección de casos
    match /cases/{caseId} {
      // Lectura individual (get) requiere autenticación
      allow get: if request.auth != null;

      // Listado (list/queries):
      // 1. Usuarios logueados pueden listar todo.
      // 2. El público puede buscar SOLO por documentId y con límite de 1 resultado.
      allow list: if request.auth != null || (
        request.query.limit == 1 && 
        request.query.filters.documentId != null
      );

      // Solo el rol 'admin' puede borrar documentos
      allow delete: if request.auth != null && getRole() == 'admin';

      // Administradores y Trabajadores Sociales pueden crear y editar
      allow create, update: if request.auth != null && (getRole() == 'admin' || getRole() == 'case-worker');

      match /novedades/{novedadId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      }
    }

    // Reglas para el buzón de mensajes (Contacto Público)
    match /mensajes/{mensajeId} {
      // Cualquier persona puede enviar un mensaje (acceso público)
      allow create: if true;
      // Solo usuarios autenticados pueden leer el buzón
      allow read: if request.auth != null;
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}