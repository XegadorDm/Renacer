
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función para identificar administradores core del proyecto (bypass temporal)
    function isCoreAdmin() {
      return request.auth != null && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() in [
               'aleksimbachi@gmail.com',
               'juancamilogiraldo@gmail.com',
               'diegomauriciopastusano@gmail.com'
             ];
    }

    function getRole() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data.role : 'none';
    }

    function isApproved() {
      // Bypass para administradores core
      if (isCoreAdmin()) {
        return true;
      }
      
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && (
        !("status" in get(userPath).data) || 
        get(userPath).data.status == 'approved'
      );
    }

    // Reglas para la vista pública segura
    match /publicCaseStatus/{documentId} {
      allow get: if true;
      allow list: if false;
      allow write: if request.auth != null && isApproved();
    }

    // Trazabilidad de consultas públicas
    match /publicCaseQueries/{queryId} {
      allow create: if true; // Cualquier persona puede registrar su consulta
      allow read, list, update, delete: if request.auth != null && isApproved(); // Solo personal puede auditar
    }

    match /cases/{caseId} {
      allow read: if request.auth != null && (isApproved() || isCoreAdmin());
      allow delete: if request.auth != null && (isCoreAdmin() || (isApproved() && getRole() == 'admin'));
      allow create, update: if request.auth != null && (isCoreAdmin() || (isApproved() && (getRole() == 'admin' || getRole() == 'case-worker')));

      match /novedades/{novedadId} {
        allow read: if request.auth != null && isApproved();
        allow create: if request.auth != null && isApproved() && request.resource.data.createdBy == request.auth.uid;
      }
    }

    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isApproved();
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isCoreAdmin() || 
        getRole() == 'admin' || 
        (request.auth.uid == userId && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.role == resource.data.role)
      );
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }
  }
}
