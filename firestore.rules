
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función para identificar administradores core (Líderes del proyecto)
    function isCoreAdmin() {
      let coreEmails = ['aleksimbachi@gmail.com', 'juancamilogiraldo@gmail.com', 'diegomauriciopastusano@gmail.com'];
      let coreUids = ['gKSHtlJQt8aVOQZPTXCTEqmYENA3']; // UID de Aleks Imbachi
      return request.auth != null && (
        request.auth.uid in coreUids ||
        (request.auth.token.email != null && request.auth.token.email.lower() in coreEmails)
      );
    }

    // Obtener el rol del usuario desde Firestore
    function getRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'none';
    }

    // Verificar si el usuario está aprobado
    function isApproved() {
      return isCoreAdmin() || (
        request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
      );
    }

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (isCoreAdmin() || getRole() == 'admin' || request.auth.uid == userId);
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Colección de Casos (REQ-003, REQ-006, REQ-008)
    match /cases/{caseId} {
      allow read, list: if request.auth != null && isApproved();
      allow create, update: if request.auth != null && isApproved();
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');

      match /novedades/{novedadId} {
        allow read, list, create: if request.auth != null && isApproved();
      }
    }

    // Vista Pública Segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true;
      allow list: if false;
      allow write: if request.auth != null && isApproved();
    }

    // Trazabilidad de Consultas Públicas
    match /publicCaseQueries/{queryId} {
      allow create: if true;
      allow read, list: if request.auth != null && isApproved();
    }

    // Notificaciones Internas
    match /notifications/{notificationId} {
      allow create: if request.auth != null && (
        isCoreAdmin() || (
          isApproved() && 
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.read == false
        )
      );
      allow read, list: if request.auth != null && (isCoreAdmin() || getRole() == 'admin' || resource.data.userId == request.auth.uid);
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Mensajes de contacto
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update, delete: if request.auth != null && isApproved();
    }
  }
}
