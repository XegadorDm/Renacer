rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - DESPLIEGUE DE EMERGENCIA FINAL
    // PROPÓSITO: Eliminar bloqueos para Juan Camilo y el equipo.
    // TIMESTAMP: 2024-05-22T18:30:00Z (FORCE GLOBAL SYNC)
    // ============================================================

    // Permitir TODO (lectura y escritura) a cualquier usuario autenticado en toda la base de datos.
    // Esto garantiza que la actualización de estados y novedades no sea bloqueada.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}