rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - DESPLIEGUE CRÍTICO FINAL
    // PROPÓSITO: Acceso TOTAL para usuarios autenticados (Admin y Asesor)
    // ESTADO: FORZANDO SINCRONIZACIÓN GLOBAL Y MODO OFFLINE
    // SYNC ID: RENACER_OFFLINE_READY_V2
    // TIMESTAMP: 2024-05-23T12:00:00Z
    // ============================================================

    // Permitir TODO (lectura y escritura) a cualquier usuario autenticado.
    // Esto elimina cualquier bloqueo para Juan Camilo y el equipo.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}