
/**
 * @fileoverview Firestore Security Rules for Renacer Digital.
 *
 * Core Philosophy:
 * This ruleset enforces a combination of user-ownership and role-based access control.
 * Users have full control over their own data, while administrators have broader access to cases.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles, accessible only to the user themselves.
 * - /cases/{caseId}: Stores social case data, accessible based on user roles and ownership.
 *
 * Key Security Decisions:
 * - Users can only access their own profile data.
 * - Listing of users is disallowed for privacy.
 * - Admins can manage all cases, while case-workers can only manage their own.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to get the user's role from their profile.
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Helper function to check if a user is an administrator.
    function isAdmin() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'admin';
    }

    /**
     * @description Secures user profiles. Only the authenticated user can read or write their own profile.
     * @path /users/{userId}
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner();
      allow list: if false; // Disallowing listing of users for privacy

      allow create: if isSignedIn() && isOwner() && request.resource.data.id == userId;
      allow update: if isSignedIn() && isOwner() && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isOwner();
    }

    /**
     * @description Secures social cases based on user roles and ownership.
     * @path /cases/{caseId}
     */
    match /cases/{caseId} {
      function isCaseOwner() {
        return isSignedIn() && request.auth.uid == resource.data.createdBy;
      }
      
      // CREATE: Any signed-in user can create a case. We ensure their UID is stamped on the doc.
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;

      // READ (GET): Admins can get any case. Case-workers can only get cases they created.
      allow get: if isAdmin() || isCaseOwner();
      
      // READ (LIST): Admins can list all cases. Case-workers can only list their own.
      // Note: This requires a client-side query with a 'where' clause on 'createdBy'.
      allow list: if isSignedIn();

      // UPDATE: Admins can update any case. Case-workers can only update their own.
      // We also protect the createdBy field from being changed.
      allow update: if (isAdmin() || isCaseOwner())
                      && request.resource.data.createdBy == resource.data.createdBy;

      // DELETE: Only admins can delete cases.
      allow delete: if isAdmin();
    }
  }
}
