
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - SISTEMA DE NOTIFICACIONES
    // DESPLIEGUE FINAL - PERMISIVIDAD CONTROLADA
    // ============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    match /cases/{caseId} {
      allow read, write: if isSignedIn();
    }
    
    match /notifications/{notificationId} {
      // Los usuarios pueden leer y actualizar sus propias notificaciones (marcar como leídas)
      allow read, update: if isSignedIn() && request.auth.uid == resource.data.userId;
      // Permite creación por parte de cualquier usuario autenticado (asesores generando notificaciones)
      allow create: if isSignedIn();
    }
  }
}
