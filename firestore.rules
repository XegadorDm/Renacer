
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Bypass directo para líderes del proyecto (Admin Core)
    // Se evalúa por UID primero para máxima seguridad y luego por Email
    function isCoreAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // Obtener datos del perfil de usuario de forma segura
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verificar si el usuario tiene estado aprobado en la DB
    function isApproved() {
      return isCoreAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().status == 'approved'
      );
    }

    // Verificar si el usuario tiene rol de administrador
    function isAdmin() {
      return isCoreAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == 'admin'
      );
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Colección de Casos (REQ-006, REQ-008)
    match /cases/{caseId} {
      allow read, list: if isApproved();
      allow create, update: if isApproved();
      allow delete: if isAdmin();

      // Trazabilidad de llamadas
      match /novedades/{novedadId} {
        allow read, list, create: if isApproved();
      }
    }

    // Vista Pública Segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true; // Lectura individual permitida por cédula
      allow list: if false; // Prohibido listar todos los casos públicamente
      allow write: if isApproved();
    }

    // Auditoría de Consultas Públicas (REQ-007)
    match /publicCaseQueries/{queryId} {
      allow create: if true;
      allow read, list: if isApproved();
    }

    // Notificaciones Internas (REQ-008)
    match /notifications/{notificationId} {
      allow create: if isAuthenticated() && isApproved();
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // Mensajes de contacto ciudadanos
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update, delete: if isApproved();
    }
  }
}
