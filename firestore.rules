rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS GLOBALES SIMPLIFICADAS PARA DESBLOQUEO TOTAL
    // Forzando despliegue - Timestamp: 2024-05-23 10:00:00
    // Permite lectura y escritura a cualquier usuario autenticado en toda la base de datos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Permisividad específica para la lista de correos autorizados (lectura pública)
    match /authorized_emails/{document=**} {
      allow read: if true;
    }
  }
}