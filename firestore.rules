rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - VERSION SIMPLIFICADA
    // PROPÓSITO: Permitir gestión a usuarios autenticados.
    // ============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    match /cases/{caseId} {
      allow read, write: if isSignedIn();
    }
  }
}