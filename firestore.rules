
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to individual case documents.
     */
    match /cases/{caseId} {
      allow get: if isSignedIn() && hasAccess();
      allow list: if isSignedIn(); // Further filtering is done on the client via query constraints

      allow create: if isSignedIn() && isNewCaseOwner();

      // Owner can update all fields, but cannot remove themselves as owner.
      allow update: if isSignedIn() && isOwner(caseId) 
                    && request.resource.data.members[request.auth.uid] == 'owner';
      
      // Editor can update data fields, but cannot change members.
      allow update: if isSignedIn() && isEditor(caseId) 
                    && request.resource.data.diff(resource.data).affectedKeys().toSet().intersection(['members']).size() == 0;

      allow delete: if isSignedIn() && isOwner(caseId);
    }
    
    match /users/{userId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ------ Helper Functions ------

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole(caseId) {
      // Safely access data, returns null if document or field doesn't exist.
      return get(/databases/$(database)/documents/cases/$(caseId)).data.members[request.auth.uid];
    }

    function hasAccess() {
      // 'resource' is the document that is being requested.
      // This ensures the user is a member of the specific case document they are trying to read.
      return request.auth.uid in resource.data.members;
    }

    function isOwner(caseId) {
      return getRole(caseId) == 'owner';
    }

    function isEditor(caseId) {
      return getRole(caseId) == 'editor';
    }
    
    function isNewCaseOwner() {
      let user = request.auth.uid;
      let members = request.resource.data.members;
      return members.size() == 1 && members[user] == 'owner';
    }
  }
}
