
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función para identificar administradores core del proyecto (Bypass de seguridad)
    // Se añade el UID de Aleks Imbachi detectado en los logs para mayor robustez
    function isCoreAdmin() {
      return request.auth != null && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        (request.auth.token.email != null && 
         (request.auth.token.email.lower() == 'aleksimbachi@gmail.com' ||
          request.auth.token.email.lower() == 'juancamilogiraldo@gmail.com' ||
          request.auth.token.email.lower() == 'diegomauriciopastusano@gmail.com'))
      );
    }

    // Obtener el rol del usuario desde su perfil en Firestore
    function getRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'none';
    }

    // Verificar si el usuario ha sido aprobado por un administrador
    function isApproved() {
      return isCoreAdmin() || (
        request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          !("status" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
        )
      );
    }

    // Reglas para la vista pública segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true; // Cualquier ciudadano puede consultar su estado por ID de cédula
      allow list: if false; // Prohibido listar todos los casos públicos por privacidad
      allow write: if request.auth != null && isApproved();
    }

    // Trazabilidad de consultas públicas (REQ-007)
    match /publicCaseQueries/{queryId} {
      allow create: if true; // Registro anónimo de auditoría para cada consulta
      allow read, list, update, delete: if request.auth != null && isApproved();
    }

    // Reglas para la colección principal de Casos (REQ-003, REQ-008)
    match /cases/{caseId} {
      allow read: if request.auth != null && isApproved();
      allow delete: if request.auth != null && (isCoreAdmin() || (isApproved() && getRole() == 'admin'));
      allow create, update: if request.auth != null && (isCoreAdmin() || (isApproved() && (getRole() == 'admin' || getRole() == 'case-worker')));

      // Subcolección de Novedades e Historial de llamadas
      match /novedades/{novedadId} {
        allow read: if request.auth != null && isApproved();
        allow create: if request.auth != null && isApproved();
      }
    }

    // Mensajes recibidos a través del formulario de contacto público
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isApproved();
    }

    // Perfiles de Usuario y Control de Acceso (REQ-004)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isCoreAdmin() || 
        getRole() == 'admin' || 
        (request.auth.uid == userId && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.role == resource.data.role)
      );
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Notificaciones Internas para seguimiento (REQ-008)
    match /notifications/{notificationId} {
      allow create: if request.auth != null && isApproved();
      allow read: if request.auth != null && (
        isCoreAdmin() || 
        getRole() == 'admin' || 
        resource.data.userId == request.auth.uid
      );
      allow update: if request.auth != null && isApproved() && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }
  }
}
