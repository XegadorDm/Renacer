rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas Renacer - Acceso total para usuarios autenticados
    // Sincronización de Emergencia: SYNC_ID_V600_NOVEDADES
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regla explícita para subcolección de novedades
    match /cases/{caseId}/novedades/{novedadId} {
      allow read, write: if request.auth != null;
    }
  }
}
