
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isApproved() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !("status" in userData) || userData.status == 'approved';
    }

    // Reglas para la colección pública segura
    match /publicCaseStatus/{documentId} {
      // Cualquier persona puede leer un estado público individual si conoce la cédula normalizada
      allow get: if true;
      // Nadie puede listar o extraer masivamente la base pública
      allow list: if false;
      // Solo personal aprobado puede escribir aquí a través de los componentes de gestión
      allow write: if request.auth != null && isApproved();
    }

    match /cases/{caseId} {
      // Acceso PRIVADO: Nadie sin autenticación puede leer la ficha completa
      allow read: if request.auth != null && isApproved();
      allow delete: if request.auth != null && isApproved() && getRole() == 'admin';
      allow create, update: if request.auth != null && isApproved() && (getRole() == 'admin' || getRole() == 'case-worker');

      match /novedades/{novedadId} {
        allow read: if request.auth != null && isApproved();
        allow create: if request.auth != null && isApproved() && request.resource.data.createdBy == request.auth.uid;
      }
    }

    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isApproved();
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        getRole() == 'admin' || 
        (request.auth.uid == userId && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.role == resource.data.role)
      );
      allow delete: if request.auth != null && getRole() == 'admin';
    }
  }
}
