rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE EMERGENCIA TOTAL - ACCESO PARA USUARIOS AUTENTICADOS
    // Fecha de despliegue forzado: 2024-05-23 20:30:00 UTC
    // Este cambio garantiza que cualquier asesor logueado pueda gestionar casos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Acceso público para la lista de correos autorizados (necesario para el registro)
    match /authorized_emails/{document=**} {
      allow read: if true;
    }
  }
}