rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // DESPLIEGUE DE EMERGENCIA: ACCESO TOTAL PARA USUARIOS AUTENTICADOS
    // ============================================================
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}