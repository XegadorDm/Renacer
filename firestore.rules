rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE EMERGENCIA ABSOLUTA - SIN RESTRICCIONES PARA USUARIOS LOGUEADOS
    // Última actualización forzada: 2024-05-23 19:15:00 UTC
    // Este cambio fuerza la re-evaluación de permisos en el servidor.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Acceso público para la lista de correos autorizados (necesario para el registro)
    match /authorized_emails/{document=**} {
      allow read: if true;
    }
  }
}