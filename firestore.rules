rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'diegomauriciopastusano@gmail.com' ||
        request.auth.token.email == 'aleksimbachi@gmail.com'
      );
    }

    match /authorized_emails/{emailId} {
      // Permitir lectura a cualquier usuario autenticado para evitar errores de listado.
      allow read: if isSignedIn(); 
      // Solo administradores maestros pueden modificar la lista.
      allow write: if isMasterAdmin();
    }
    
    match /cases/{caseId} {
      // Permitir lectura a todos los autenticados.
      allow read: if isSignedIn();
      // Permitir creación a cualquier autenticado.
      allow create: if isSignedIn();
      // Permitir edición/borrado a administradores o si el usuario tiene permisos específicos.
      allow update, delete: if isMasterAdmin() || (resource.data.members[request.auth.uid] == 'owner');
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterAdmin());
    }
  }
}
// Force deployment update - Ver. 1.3.0 - Permissions and Access Stability