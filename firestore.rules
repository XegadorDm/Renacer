rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DESPLIEGUE CRÍTICO DE EMERGENCIA: 2025-02-25 00:10:00 UTC
    // Este cambio fuerza la invalidación de caché de reglas en el servidor.
    
    // Regla global: Usuarios autenticados tienen acceso total a todo.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Regla explícita para la colección de casos (prioridad alta).
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }

    // Acceso público necesario para la lista blanca durante el registro.
    match /authorized_emails/{emailId} {
      allow read: if true;
    }
  }
}