
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función para identificar administradores core (Líderes del proyecto)
    // Bypass directo por UID y Email para garantizar acceso total inmediato
    function isCoreAdmin() {
      return request.auth != null && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.uid == 'juancamilogiraldo-uid-placeholder' ||
        request.auth.uid == 'diegomauricio-uid-placeholder' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // Verificar si el usuario está aprobado administrativamente
    function isApproved() {
      return isCoreAdmin() || (
        request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
      );
    }

    // Obtener el rol del usuario de forma segura
    function getRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'none';
    }

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if request.auth != null && (isCoreAdmin() || request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (isCoreAdmin() || getRole() == 'admin' || request.auth.uid == userId);
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Colección de Casos
    match /cases/{caseId} {
      allow read, list: if request.auth != null && isApproved();
      allow create: if request.auth != null && isApproved();
      allow update: if request.auth != null && isApproved();
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');

      // Trazabilidad de llamadas (REQ-008)
      match /novedades/{novedadId} {
        allow read, list, create: if request.auth != null && isApproved();
      }
    }

    // Vista Pública Segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true;
      allow list: if false;
      allow write: if request.auth != null && isApproved();
    }

    // Trazabilidad de Consultas Públicas (REQ-007)
    match /publicCaseQueries/{queryId} {
      allow create: if true;
      allow read, list: if request.auth != null && isApproved();
    }

    // Notificaciones Internas (REQ-008)
    match /notifications/{notificationId} {
      allow create: if request.auth != null
        && isApproved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.caseId is string
        && request.resource.data.message is string
        && request.resource.data.createdAt is string
        && request.resource.data.read == false;

      allow read: if request.auth != null 
        && isApproved()
        && (isCoreAdmin() || getRole() == 'admin' || resource.data.userId == request.auth.uid);

      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid 
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);

      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Mensajes de contacto ciudadanos
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update, delete: if request.auth != null && isApproved();
    }
  }
}
