rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA UNIVERSAL: Cualquier usuario logueado tiene acceso total.
    // Esto garantiza que ningún asesor o administrador sea bloqueado.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Reglas de acceso público (Para consulta REQ-007 y contacto)
    match /publicCaseStatus/{documentId} {
      allow get: if true;
    }
    match /publicCaseQueries/{queryId} {
      allow create: if true;
    }
    match /mensajes/{mensajeId} {
      allow create: if true;
    }
    match /authorized_emails/{id} {
      allow read: if true;
    }
  }
}