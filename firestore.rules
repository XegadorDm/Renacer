rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PERMISIVIDAD TOTAL PARA USUARIOS AUTENTICADOS
    // Esto garantiza que cualquier asesor o administrador logueado pueda 
    // crear, leer, editar y cambiar estados sin bloqueos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Nota: Se han eliminado las reglas restrictivas de administración 
    // para permitir el flujo de trabajo inmediato.
  }
}