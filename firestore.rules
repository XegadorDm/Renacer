
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - SISTEMA LIMPIO
    // PROPÓSITO: Permitir gestión de casos para usuarios autenticados.
    // TIMESTAMP: 2024-05-21T00:00:00Z
    // ============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
