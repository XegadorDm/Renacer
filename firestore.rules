rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD SIMPLIFICADAS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Administradores Core: Acceso total garantizado por UID o Email
    function isCoreAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // Usuario Aprobado: Es Core Admin o tiene estado 'approved' en su documento
    function isApproved() {
      return isCoreAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
      );
    }

    // Administrador: Es Core Admin o tiene rol 'admin'
    function isAdmin() {
      return isCoreAdmin() || (
        isApproved() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios: Gestión de perfiles y permisos
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Colección de Casos: Acceso total para personal aprobado (Online y Offline)
    match /cases/{caseId} {
      allow get, list, create, update: if isApproved();
      allow delete: if isAdmin();

      // Historial de novedades (Trazabilidad)
      match /novedades/{novedadId} {
        allow read, list, create: if isApproved();
      }
    }

    // Vista Pública Segura (REQ-007): Solo lectura por cédula para ciudadanos
    match /publicCaseStatus/{documentId} {
      allow get: if true; 
      allow list: if false;
      allow write: if isApproved();
    }

    // Auditoría de Consultas Públicas
    match /publicCaseQueries/{queryId} {
      allow create: if true; 
      allow read, list: if isApproved(); 
    }

    // Notificaciones Internas
    match /notifications/{notificationId} {
      allow create, read, update: if isApproved();
      allow delete: if isAdmin();
    }

    // Mensajes de contacto (Buzón)
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update: if isApproved();
      allow delete: if isAdmin();
    }
    
    // Lista de correos autorizados
    match /authorized_emails/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}