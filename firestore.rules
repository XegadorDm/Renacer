rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions para validación de permisos
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isApproved() {
      // Se obtiene la data del usuario una sola vez para eficiencia
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // Permitir acceso si el campo 'status' no existe (usuarios antiguos) o si es 'approved'
      return !("status" in userData) || userData.status == 'approved';
    }

    // Reglas para la colección de casos: Acceso privado para personal aprobado
    match /cases/{caseId} {
      allow read: if request.auth != null && isApproved();
      allow delete: if request.auth != null && isApproved() && getRole() == 'admin';
      allow create, update: if request.auth != null && isApproved() && (getRole() == 'admin' || getRole() == 'case-worker');

      match /novedades/{novedadId} {
        allow read: if request.auth != null && isApproved();
        allow create: if request.auth != null && isApproved() && request.resource.data.createdBy == request.auth.uid;
      }
    }

    // Reglas para el buzón de mensajes (Contacto Público)
    match /mensajes/{mensajeId} {
      // Cualquier persona puede enviar un mensaje (público)
      allow create: if true;
      // Solo personal autenticado y aprobado puede ver, marcar como resuelto o eliminar mensajes
      allow read, update, delete: if request.auth != null && isApproved();
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles (necesario para verificar su propio estado)
      allow read: if request.auth != null;
      
      // Creación permitida para nuevos usuarios durante el registro
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Solo administradores pueden cambiar roles o estados de otros
      // Los usuarios pueden actualizar su propio perfil siempre que no alteren su rol o estado
      allow update: if request.auth != null && (
        getRole() == 'admin' || 
        (request.auth.uid == userId && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.role == resource.data.role)
      );
      
      allow delete: if request.auth != null && getRole() == 'admin';
    }
  }
}