rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - ACCESO TOTAL GARANTIZADO
    // PROPÓSITO: Eliminar de una vez por todas el error de permisos.
    // SYNC ID: FORCE_SYNC_RENACER_ABSULUTO_V200
    // TIMESTAMP: 2024-05-24T19:00:00Z
    // ============================================================

    match /{document=**} {
      // 1. Permitir todo si el usuario está autenticado (Regla General)
      allow read, write: if request.auth != null;
      
      // 2. Permiso explícito por correo para evitar cualquier duda del sistema
      allow read, write: if request.auth.token.email == "juancamilogiraldo@gmail.com";
      allow read, write: if request.auth.token.email == "diegomauriciopastusano@gmail.com";
    }
  }
}