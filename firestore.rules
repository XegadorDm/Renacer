rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Función de administrador robusta con correos autorizados explícitamente
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'diegomauriciopastusano@gmail.com' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    match /cases/{caseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (resource.data.members[request.auth.uid] == 'owner');
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /authorized_emails/{emailId} {
      // Permitimos lectura para usuarios autenticados para que el Dashboard no falle
      // También permitimos lectura pública para el proceso de validación en el registro
      allow read: if true;
      // Solo administradores pueden añadir o eliminar de la lista blanca
      allow write: if isAdmin();
    }
  }
}