rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RENACER - DESPLIEGUE CRÍTICO DE EMERGENCIA V700
    // Sincronización forzada para resolver error de permisos en subcolección 'novedades'
    // Permitir acceso total de lectura y escritura a cualquier usuario autenticado
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regla explícita para asegurar el acceso a subcolecciones
    match /cases/{caseId}/novedades/{novedadId} {
      allow read, write: if request.auth != null;
    }
    
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }
  }
}