rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas de Seguridad Renacer - Estado Estable
    // Permite lectura y escritura a cualquier usuario autenticado.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}