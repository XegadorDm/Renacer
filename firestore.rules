rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RENACER - SISTEMA DE SEGURIDAD TOTAL V2000
    // REGLA DEFINITIVA: Acceso total para usuarios autenticados.
    // Esta regla permite leer, crear, actualizar y BORRAR cualquier documento si el usuario está logueado.
    // SYNC_ID: RENACER_FORCE_DEPLOY_V2000_ULTIMATE_ACCESS
    
    match /{document=**} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}