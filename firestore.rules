rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Bypass directo e infalible para administradores del proyecto (Líderes)
    function isCoreAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // Verifica si el usuario tiene un perfil aprobado en la colección 'users'
    function isApproved() {
      // Prioridad 1: Líderes del proyecto
      if (isCoreAdmin()) { return true; }
      
      // Prioridad 2: Usuarios con documento físico aprobado
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // Verifica si el usuario tiene rol de administrador
    function isAdmin() {
      if (isCoreAdmin()) { return true; }
      return isApproved() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Colección de Casos (REQ-006, REQ-008)
    match /cases/{caseId} {
      // Solo usuarios aprobados pueden ver o listar casos
      allow get, list: if isApproved();
      
      // Solo usuarios aprobados con rol admin o case-worker pueden crear/editar
      allow create, update: if isApproved();
      
      // Solo administradores pueden borrar casos
      allow delete: if isAdmin();

      // Trazabilidad de novedades
      match /novedades/{novedadId} {
        allow read, list, create: if isApproved();
      }
    }

    // Vista Pública Segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true; // Lectura individual permitida por cédula para ciudadanos
      allow list: if false; // Prohibido listar todos los casos públicamente
      allow write: if isApproved(); // Solo internos aprobados escriben el espejo
    }

    // Auditoría de Consultas Públicas (REQ-007)
    match /publicCaseQueries/{queryId} {
      allow create: if true; // Público puede registrar que consultó
      allow read, list: if isApproved(); // Solo internos ven auditoría
    }

    // Notificaciones Internas (REQ-008)
    match /notifications/{notificationId} {
      allow create: if isApproved();
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // Mensajes de contacto ciudadanos
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update: if isApproved();
      allow delete: if isAdmin();
    }
  }
}