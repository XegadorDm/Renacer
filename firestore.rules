rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SYNC_ID: RENACER_RBAC_FINAL_V1600_STABLE

    // Función auxiliar para obtener el rol del usuario desde su perfil
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Reglas para la colección de casos
    match /cases/{caseId} {
      // Todos los usuarios autenticados pueden leer casos
      allow read: if request.auth != null;

      // Solo los usuarios con rol 'admin' pueden eliminar casos
      allow delete: if request.auth != null && getRole() == 'admin';

      // Administradores y Trabajadores Sociales (case-worker) pueden crear y editar casos
      allow create, update: if request.auth != null && (getRole() == 'admin' || getRole() == 'case-worker');

      // Reglas para la subcolección novedades
      match /novedades/{novedadId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      }
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      // Los usuarios pueden leer y escribir su propio perfil
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}