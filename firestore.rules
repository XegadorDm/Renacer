rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE EMERGENCIA TOTAL - ACCESO TOTAL A USUARIOS AUTENTICADOS
    // PROPÓSITO: Eliminar bloqueos de permisos en cambio de estado.
    // ÚLTIMA ACTUALIZACIÓN FORZADA: 2024-03-20 17:30:00 (GMT-5)
    // ============================================================
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Regla explícita para la colección de casos para asegurar updates inmediatos
    match /cases/{caseId} {
      allow get, list, create, update, delete: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /authorized_emails/{emailId} {
      allow read, write: if request.auth != null;
    }
  }
}