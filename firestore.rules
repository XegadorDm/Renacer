rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - DESPLIEGUE DEFINITIVO V10
    // PROPÓSITO: Acceso TOTAL para cualquier usuario autenticado
    // ESTADO: FORZANDO SINCRONIZACIÓN GLOBAL - SIN RESTRICCIONES
    // SYNC ID: RENACER_DEPLOY_FINAL_FIX_V10
    // TIMESTAMP: 2024-05-23T16:00:00Z
    // ============================================================

    match /{document=**} {
      // Permitir TODO (lectura y escritura) a cualquier usuario autenticado.
      // Esto elimina cualquier bloqueo para Juan Camilo, Diego y todo el equipo.
      allow read, write: if request.auth != null;
    }
  }
}