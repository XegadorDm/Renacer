
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Función de administrador robusta con correos hardcodeados para evitar bloqueos iniciales
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'diegomauriciopastusano@gmail.com' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    match /cases/{caseId} {
      // Todos los usuarios autenticados pueden ver la lista compartida de casos
      allow read: if isSignedIn();
      // Cualquier usuario autenticado puede crear un caso
      allow create: if isSignedIn();
      // Solo administradores o el dueño del caso pueden editar/borrar
      allow update, delete: if isAdmin() || (resource.data.members[request.auth.uid] == 'owner');
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /authorized_emails/{emailId} {
      // Permitimos lectura total para usuarios autenticados para evitar errores de carga en el dashboard
      // y lectura pública (vía query) para el flujo de registro.
      allow read: if true;
      // Solo los administradores reales pueden añadir o quitar correos de la lista
      allow write: if isAdmin();
    }
  }
}
