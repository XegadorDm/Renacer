rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE EMERGENCIA ABSOLUTA - Timestamp: 2024-05-23 15:55:00
    // Permite lectura y escritura a cualquier usuario autenticado en toda la base de datos.
    // Esto garantiza que el cambio de estado de los casos funcione sin bloqueos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Acceso público para la lista de correos si fuera necesario
    match /authorized_emails/{document=**} {
      allow read: if true;
    }
  }
}