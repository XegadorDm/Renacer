rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE EMERGENCIA TOTAL - Timestamp: 2024-05-23 11:35:00
    // Permite lectura y escritura a cualquier usuario autenticado en toda la base de datos.
    // Esto elimina cualquier error de "insufficient permissions" de forma inmediata.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Acceso público para la lista de correos si fuera necesario
    match /authorized_emails/{document=**} {
      allow read: if true;
    }
  }
}