rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RENACER - DESPLIEGUE FINAL DE EMERGENCIA V1000
    // Sincronización forzada definitiva para resolver error de permisos de forma definitiva
    // Identificador de sincronización: SYNC_ID_RENACER_FINAL_V1000_ULTIMATE
    
    // Regla de Oro: Cualquier usuario autenticado tiene acceso total a TODO
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Regla explícita para la subcolección de novedades (prioridad alta)
    match /cases/{caseId}/novedades/{novedadId} {
      allow read, write: if request.auth != null;
    }

    // Reglas específicas para colecciones principales
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}