rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RENACER - SISTEMA DE SEGURIDAD TOTAL V3000
    // ESTA REGLA ES ABSOLUTA Y DEFINITIVA: 
    // Permite lectura y escritura total (create, update, delete) 
    // a cualquier usuario que haya iniciado sesión.
    // SYNC_ID: RENACER_ULTIMATE_STABLE_V3000_FULL_ACCESS
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}