rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RENACER - SISTEMA DE SEGURIDAD TOTAL V1500
    // REGLA DEFINITIVA: Acceso total para usuarios autenticados.
    // SYNC_ID: RENACER_FINAL_STABLE_V1500_TOTAL_ACCESS
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Permitimos TODO a cualquier usuario que haya iniciado sesión
    // Esto cubre casos, novedades, usuarios y cualquier otra colección
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Reglas específicas por si el motor de Firebase requiere mayor precisión
    match /cases/{caseId} {
      allow read, write: if isAuthenticated();
      
      match /novedades/{novedadId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /authorized_emails/{emailId} {
      allow read, write: if isAuthenticated();
    }
  }
}