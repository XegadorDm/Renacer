rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Administradores Core: Bypass inmediato por UID o Email verificado
    function isCoreAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        request.auth.token.email == 'aleksimbachi@gmail.com' ||
        request.auth.token.email == 'juancamilogiraldo@gmail.com' ||
        request.auth.token.email == 'diegomauriciopastusano@gmail.com'
      );
    }

    // Obtener rol del usuario de forma segura
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Usuario Aprobado: Es Core Admin o tiene estado 'approved' en su documento
    function isApproved() {
      if (isCoreAdmin()) {
        return true;
      }
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // Administrador: Es Core Admin o tiene rol 'admin' aprobado
    function isAdmin() {
      if (isCoreAdmin()) {
        return true;
      }
      return isApproved() && getRole() == 'admin';
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Colección de Casos (REQ-006, REQ-008)
    match /cases/{caseId} {
      allow get, list: if isApproved();
      allow create, update: if isApproved();
      allow delete: if isAdmin();

      // Trazabilidad de novedades
      match /novedades/{novedadId} {
        allow read, list, create: if isApproved();
      }
    }

    // Vista Pública Segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true; 
      allow list: if false;
      allow write: if isApproved();
    }

    // Auditoría de Consultas Públicas
    match /publicCaseQueries/{queryId} {
      allow create: if true; 
      allow read, list: if isApproved(); 
    }

    // Notificaciones Internas
    match /notifications/{notificationId} {
      allow create, read, update: if isApproved();
      allow delete: if isAdmin();
    }

    // Buzón de Mensajes (REQ-008)
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update: if isApproved();
      allow delete: if isAdmin();
    }
    
    // Lista de correos autorizados para registro
    match /authorized_emails/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}