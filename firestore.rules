rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DESPLIEGUE DE EMERGENCIA GLOBAL: 2025-02-24 19:45:00 UTC
    // Se permite acceso total a cualquier usuario autenticado para eliminar bloqueos de permisos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Acceso específico para la colección de casos para asegurar la gestión
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }

    // Acceso público para la lista blanca de correos
    match /authorized_emails/{document=**} {
      allow read: if true;
    }
  }
}