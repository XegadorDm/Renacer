
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función para identificar administradores core del proyecto
    function isCoreAdmin() {
      return request.auth != null && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() in [
               'aleksimbachi@gmail.com',
               'juancamilogiraldo@gmail.com',
               'diegomauriciopastusano@gmail.com'
             ];
    }

    function getRole() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data.role : 'none';
    }

    function isApproved() {
      // Bypass para administradores core
      if (isCoreAdmin()) {
        return true;
      }
      
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && (
        !("status" in get(userPath).data) || 
        get(userPath).data.status == 'approved'
      );
    }

    // Reglas para la vista pública segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true; // Cualquier ciudadano puede consultar por ID de cédula
      allow list: if false; // Prohibido listar todos los casos públicos
      allow write: if request.auth != null && isApproved();
    }

    // Trazabilidad de consultas públicas (REQ-007)
    match /publicCaseQueries/{queryId} {
      allow create: if true; // Cualquier persona puede registrar su consulta de forma anónima
      allow read, list, update, delete: if request.auth != null && isApproved();
    }

    // Reglas para la colección principal de Casos (REQ-003, REQ-008)
    match /cases/{caseId} {
      allow read: if request.auth != null && (isApproved() || isCoreAdmin());
      allow delete: if request.auth != null && (isCoreAdmin() || (isApproved() && getRole() == 'admin'));
      allow create, update: if request.auth != null && (isCoreAdmin() || (isApproved() && (getRole() == 'admin' || getRole() == 'case-worker')));

      // Subcolección de Novedades/Trazabilidad (REQ-008)
      match /novedades/{novedadId} {
        allow read: if request.auth != null && isApproved();
        allow create: if request.auth != null && isApproved();
      }
    }

    // Mensajes del Buzón Público
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isApproved();
    }

    // Perfiles de Usuario (REQ-004)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isCoreAdmin() || 
        getRole() == 'admin' || 
        (request.auth.uid == userId && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.role == resource.data.role)
      );
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Notificaciones Internas (REQ-008)
    match /notifications/{notificationId} {
      allow create: if request.auth != null
        && isApproved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.caseId is string
        && request.resource.data.message is string
        && request.resource.data.createdAt is string
        && request.resource.data.read == false;

      allow read: if request.auth != null
        && isApproved()
        && (
          getRole() == 'admin' ||
          resource.data.userId == request.auth.uid
        );

      allow update: if request.auth != null
        && isApproved()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);

      allow delete: if request.auth != null
        && isApproved()
        && getRole() == 'admin';
    }
  }
}
