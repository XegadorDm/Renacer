rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Validación de administrador robusta para acceso total
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'diegomauriciopastusano@gmail.com' ||
        request.auth.token.email == 'aleksimbachi@gmail.com'
      );
    }

    match /cases/{caseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (resource.data.members[request.auth.uid] == 'owner');
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /authorized_emails/{emailId} {
      // PERMISOS DE LECTURA GLOBALES para evitar errores en registro y dashboard
      allow read: if true; 
      
      // Solo los administradores pueden modificar la lista de autorizados
      allow write: if isAdmin();
    }
  }
}