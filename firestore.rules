rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIÓN DE AUTENTICACIÓN BÁSICA ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- REGLAS SIMPLIFICADAS (ACCESO TOTAL DASHBOARD) ---
    // Cualquier usuario que logre entrar al dashboard (autenticado) puede gestionar la info.

    // Colección de Casos (REQ-006, REQ-008)
    match /cases/{caseId} {
      allow read, write: if isAuthenticated();

      // Subcolección de novedades
      match /novedades/{novedadId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Colección de Usuarios: Gestión de perfil propio y visualización de equipo
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Vista Pública Segura (REQ-007): Lectura por ID para ciudadanos, escritura para asesores
    match /publicCaseStatus/{documentId} {
      allow get: if true; 
      allow list: if false;
      allow write: if isAuthenticated();
    }

    // Auditoría de Consultas Públicas
    match /publicCaseQueries/{queryId} {
      allow create: if true; 
      allow read: if isAuthenticated(); 
    }

    // Notificaciones y Mensajes
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, write: if isAuthenticated();
    }
    
    // Lista de correos autorizados (si existe)
    match /authorized_emails/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}