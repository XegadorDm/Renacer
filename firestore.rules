rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función para identificar administradores core (Líderes del proyecto)
    // Se incluye el UID directo para evitar cualquier fallo de permisos en la cuenta principal
    function isCoreAdmin() {
      return request.auth != null && (
        request.auth.uid == 'gKSHtlJQt8aVOQZPTXCTEqmYENA3' ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'aleksimbachi@gmail.com' ||
          request.auth.token.email.lower() == 'juancamilogiraldo@gmail.com' ||
          request.auth.token.email.lower() == 'diegomauriciopastusano@gmail.com'
        ))
      );
    }

    // Obtener el rol del usuario desde Firestore de forma segura
    function getRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'none';
    }

    // Verificar si el usuario está aprobado
    // Los admins core siempre están aprobados
    function isApproved() {
      return isCoreAdmin() || (
        request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
      );
    }

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (isCoreAdmin() || getRole() == 'admin' || request.auth.uid == userId);
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Colección de Casos (REQ-003, REQ-006, REQ-008)
    match /cases/{caseId} {
      allow read, list: if request.auth != null && isApproved();
      allow create, update: if request.auth != null && isApproved();
      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');

      match /novedades/{novedadId} {
        allow read, list, create: if request.auth != null && isApproved();
      }
    }

    // Vista Pública Segura (REQ-007)
    match /publicCaseStatus/{documentId} {
      allow get: if true;
      allow list: if false;
      allow write: if request.auth != null && isApproved();
    }

    // Trazabilidad de Consultas Públicas (Audit Log)
    match /publicCaseQueries/{queryId} {
      allow create: if true;
      allow read, list: if request.auth != null && isApproved();
    }

    // Notificaciones Internas (REQ-008)
    match /notifications/{notificationId} {
      allow create: if request.auth != null
        && isApproved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.read == false;

      allow read: if request.auth != null 
        && (isCoreAdmin() || getRole() == 'admin' || resource.data.userId == request.auth.uid);

      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid 
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);

      allow delete: if request.auth != null && (isCoreAdmin() || getRole() == 'admin');
    }

    // Mensajes de contacto ciudadanos
    match /mensajes/{mensajeId} {
      allow create: if true;
      allow read, list, update, delete: if request.auth != null && isApproved();
    }
  }
}