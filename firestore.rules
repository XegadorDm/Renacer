rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RENACER - DESPLIEGUE FINAL DE EMERGENCIA V900
    // Sincronización forzada para resolver error de permisos de forma definitiva
    // Identificador de sincronización: SYNC_ID_RENACER_FINAL_V900_STABLE
    
    // Regla sugerida por Juan Camilo para subcolección de novedades
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
      
      match /novedades/{novedadId} {
        allow read, write: if request.auth != null;
      }
    }

    // Regla general para permitir acceso a usuarios autenticados (ADMINISTRADOR y TRABAJADORSOCIAL)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}