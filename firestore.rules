rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // DESPLIEGUE DE EMERGENCIA TOTAL: 2025-03-11 21:10:00 UTC
    // PROPÓSITO: ELIMINAR CUALQUIER BLOQUEO DE PERMISOS.
    // ============================================================
    
    function isAuthed() {
      return request.auth != null;
    }
    
    // Regla global definitiva: Usuarios autenticados pueden hacer todo.
    match /{document=**} {
      allow read, create, update, delete: if isAuthed();
    }

    // Reglas específicas reforzadas para la colección de casos
    match /cases/{caseId} {
      allow read, create, update, delete: if isAuthed();
    }

    match /users/{userId} {
      allow read, create, update, delete: if isAuthed();
    }

    match /authorized_emails/{emailId} {
      allow read: if true;
      allow create, update, delete: if isAuthed();
    }
  }
}