rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DESPLIEGUE DE EMERGENCIA TOTAL: 2025-02-24 21:50:00 UTC
    // Este cambio fuerza la propagación inmediata de reglas permisivas para usuarios autenticados.
    // Se permite lectura y escritura total (create, update, delete) a cualquier usuario que haya iniciado sesión.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Acceso público necesario para la lista blanca de correos durante el registro
    match /authorized_emails/{emailId} {
      allow read: if true;
    }
  }
}