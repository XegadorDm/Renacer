rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SYNC_ID: RENACER_PRIVACY_V2500

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Reglas para la colección de casos: Acceso 100% privado para personal autenticado
    match /cases/{caseId} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null && getRole() == 'admin';
      allow create, update: if request.auth != null && (getRole() == 'admin' || getRole() == 'case-worker');

      match /novedades/{novedadId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      }
    }

    // Reglas para el buzón de mensajes (Contacto Público)
    match /mensajes/{mensajeId} {
      // Público puede crear (enviar mensaje)
      allow create: if true;
      // Solo personal autenticado puede leer el buzón
      allow read: if request.auth != null;
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}