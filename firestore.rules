rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // DESPLIEGUE DE EMERGENCIA TOTAL: 2025-03-11 21:25:00 UTC
    // PROPÓSITO: ELIMINAR CUALQUIER BLOQUEO DE PERMISOS PARA USUARIOS AUTENTICADOS.
    // ============================================================
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Reglas específicas adicionales para asegurar acceso total a casos
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}