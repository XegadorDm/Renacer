rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // REGLAS DE SEGURIDAD RENACER - DESPLIEGUE CRÍTICO FINAL
    // PROPÓSITO: Eliminar DEFINITIVAMENTE el error de permisos.
    // ACCESO: Total para cualquier usuario autenticado (Admin o Asesor).
    // SYNC ID: FORCE_SYNC_RENACER_DE_EMERGENCIA_V100
    // TIMESTAMP: 2024-05-24T15:00:00Z
    // ============================================================

    match /{document=**} {
      // Permitir TODO (lectura y escritura) a cualquier usuario autenticado.
      // Esto elimina cualquier bloqueo para Juan Camilo, Diego y el resto del equipo.
      allow read, write: if request.auth != null;
    }
  }
}