rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions para validación de permisos
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isApproved() {
      // Se obtiene la data del usuario
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // PERMITIR ACCESO:
      // 1. Si el campo 'status' no existe (usuarios antiguos/legados)
      // 2. Si el campo 'status' es explícitamente 'approved'
      return !("status" in userData) || userData.status == 'approved';
    }

    // Reglas para la colección de casos
    match /cases/{caseId} {
      // Acceso privado para personal aprobado
      allow read: if request.auth != null && isApproved();
      allow delete: if request.auth != null && isApproved() && getRole() == 'admin';
      allow create, update: if request.auth != null && isApproved() && (getRole() == 'admin' || getRole() == 'case-worker');

      // REQ-007: Permitir consulta pública filtrada por cédula (documentId)
      // Solo se permite listar si se filtra por un documentId específico y el límite es 1
      allow list: if request.query.limit <= 1 && request.query.filters.documentId != null;

      match /novedades/{novedadId} {
        allow read: if request.auth != null && isApproved();
        allow create: if request.auth != null && isApproved() && request.resource.data.createdBy == request.auth.uid;
      }
    }

    // Reglas para el buzón de mensajes (Contacto Público)
    match /mensajes/{mensajeId} {
      // Cualquier persona puede enviar un mensaje (público) desde la landing page
      allow create: if true;
      // Solo personal autenticado y aprobado puede ver, gestionar o eliminar mensajes
      allow read, update, delete: if request.auth != null && isApproved();
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        getRole() == 'admin' || 
        (request.auth.uid == userId && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.role == resource.data.role)
      );
      allow delete: if request.auth != null && getRole() == 'admin';
    }
  }
}