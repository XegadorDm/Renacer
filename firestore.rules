rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // DESPLIEGUE CRÍTICO DE EMERGENCIA: 2025-03-11 19:25:00 UTC
    // Se abren permisos totales para usuarios autenticados para garantizar la fluidez en la gestión de casos.
    
    function loggedIn() {
      return request.auth != null;
    }
    
    // Permisos para la colección de casos
    match /cases/{caseId} {
      allow read, write: if loggedIn();
    }

    // Permisos para perfiles de usuario
    match /users/{userId} {
      allow read, write: if loggedIn();
    }

    // Permisos para la lista de correos autorizados
    match /authorized_emails/{emailId} {
      allow read: if true;
      allow write: if loggedIn();
    }
    
    // Regla global de respaldo: Todo usuario logueado puede leer y escribir.
    match /{document=**} {
      allow read, write: if loggedIn();
    }
  }
}